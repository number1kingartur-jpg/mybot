BOT_TOKEN=your_bot_token_here
# Telegram ID владельца (для /channel_post и безлимит фото)
ADMIN_ID=
# Автовыкладка в канал
TELEGRAM_CHANNEL_ID=@kingmode_fit
CHANNEL_POST_ENABLED=1
# Оформление при старте (опционально)
CHANNEL_TITLE=KINGMODE
CHANNEL_DESCRIPTION=Метод: план → цифры → результат. Написать → @arturking10 · Бот → @Raschettbot
KINGMODE_SITE_URL=https://твой-сайт.ru
KINGMODE_DM_USERNAME=arturking10
# CHANNEL_PHOTO_URL=https://example.com/cover.jpg
# Cron: пн/ср/пт 10:00 (Asia/Bangkok). Пример ежедневно: 0 10 * * *
CHANNEL_POST_CRON=0 10 * * 1,3,5
BOT_USERNAME=Raschettbot
# Тест: безлимит фото для всех (1 = вкл, убери после теста)
MEAL_PHOTO_UNLIMITED=1
# Анализ еды по фото — основной (бесплатно, aistudio.google.com/apikey)
GEMINI_API_KEY=
# Запасные ключи Gemini с других Google-аккаунтов (удваивают лимит)
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# Бесплатный fallback без карты — 50 фото/день (openrouter.ai/keys)
OPENROUTER_API_KEY=
# Опционально: голос + ещё один fallback (console.groq.com/keys)
GROQ_API_KEY=
