{
  "name": "mybot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --transpile-only src/index.ts",
    "build": "tsc && node scripts/check-channel-posts.mjs",
    "start": "node dist/index.js",
    "setup:channel": "node scripts/setup-channel.mjs",
    "channel:sync-photos": "npm run build && node scripts/sync-channel-photos.mjs",
    "channel:publish": "node scripts/publish-channel-posts.mjs"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "grammy": "^1.31.0",
    "node-cron": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
